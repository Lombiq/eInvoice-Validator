<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
  </ItemGroup>

  <PropertyGroup>
    <EInvoiceValidator>..\Lombiq.EInvoiceValidator\Lombiq.EInvoiceValidator.csproj</EInvoiceValidator>
  </PropertyGroup>

  <ItemGroup Condition="!Exists($(EInvoiceValidator))">
    <PackageReference Include="Lombiq.EInvoiceValidator" Version="1.0.0"/>
  </ItemGroup>

  <ItemGroup Condition="Exists($(EInvoiceValidator))">
    <ProjectReference Include="..\Lombiq.EInvoiceValidator\Lombiq.EInvoiceValidator.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="BenchmarkResults\" />
    <Folder Include="BenchmarkRunLogs\" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\Lombiq.EInvoiceValidator.Sample\SampleInvoices\**\*.xml">
      <Link>SampleInvoices\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
