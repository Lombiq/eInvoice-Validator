<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.0" />
    <PackageReference Include="xunit.v3" Version="2.0.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Condition="'$(NuGetBuild)' == 'true'">
    <PackageReference Include="Lombiq.Tests" Version="5.0.0"/>
    <PackageReference Include="Lombiq.EInvoiceValidator" Version="1.0.0"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Condition="'$(NuGetBuild)' != 'true'" Include="..\..\..\..\test\Lombiq.Tests\Lombiq.Tests.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <EInvoiceValidator>..\Lombiq.EInvoiceValidator\Lombiq.EInvoiceValidator.csproj</EInvoiceValidator>
  </PropertyGroup>

  <ItemGroup Condition="!Exists($(EInvoiceValidator))">
    <PackageReference Include="Lombiq.EInvoiceValidator" Version="1.0.0"/>
  </ItemGroup>

  <ItemGroup Condition="Exists($(EInvoiceValidator))">
    <ProjectReference Include="..\Lombiq.EInvoiceValidator\Lombiq.EInvoiceValidator.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="UnitTests\SampleInvoices\**\*.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
